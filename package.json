{
  "name": "@phototology/sdk",
  "version": "1.0.1",
  "description": "TypeScript SDK for the Phototology AI vision API",
  "license": "MIT",
  "homepage": "https://phototology.com",
  "bugs": {
    "url": "https://github.com/phototology-ai/phototology-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phototology-ai/phototology-sdk.git"
  },
  "keywords": [
    "phototology",
    "vision",
    "ai",
    "photo-intelligence",
    "image-analysis",
    "mcp",
    "sdk"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": "bin/init.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "prepublishOnly": "pnpm build && node ../../scripts/check-publish-drift.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
